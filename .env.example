# ==========================================
# 股票智能分析系统 - 环境变量模板
# 复制为 .env 并填写实际值
# ==========================================

# === 数据库配置 ===
DATABASE_URL=postgresql://stock_user:stock_pass@localhost:5432/stock_analysis

# === Redis 缓存配置 ===
REDIS_URL=redis://localhost:6379/0

# === 数据源配置 ===
# BaoStock 账号（可选，未配置时使用 AKShare）
BAOSTOCK_USER=
BAOSTOCK_PASSWORD=

# === 应用安全 ===
# 生产环境请修改为强密码
SECRET_KEY=stock-analysis-secret-key-change-me

# === 运行模式 ===
# true = 开发模式（热更新、详细日志）
# false = 生产模式
DEBUG=false

# === 腾讯云部署配置（可选） ===
# 服务器IP
TENCENT_CLOUD_IP=
# SSH 密钥路径
TENCENT_CLOUD_KEY=
# Docker Registry 配置（如需推送到腾讯云镜像仓库）
TENCENT_REGISTRY_NAMESPACE=
TENCENT_REGISTRY_PASSWORD=
